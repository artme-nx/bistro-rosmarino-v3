{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "ink": {
        "950": { "$value": "#211D17", "$type": "color" },
        "900": { "$value": "#2B271F", "$type": "color" },
        "700": { "$value": "#4A4436", "$type": "color" },
        "500": { "$value": "#756D5B", "$type": "color" }
      },
      "paper": {
        "50": { "$value": "#F7F2E7", "$type": "color" },
        "100": { "$value": "#EFE6D2", "$type": "color" },
        "300": { "$value": "#DED0AE", "$type": "color" }
      },
      "sage": {
        "300": { "$value": "#A9BB9C", "$type": "color" },
        "500": { "$value": "#5C7A63", "$type": "color" },
        "700": { "$value": "#3E5643", "$type": "color" },
        "900": { "$value": "#223026", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-playfair), 'Playfair Display', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-karla), system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "border": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.sage.500}", "$type": "color" },
    "radius": { "$value": "0.85rem", "$type": "dimension" },
    "sage": { "$value": "{primitive.color.sage.500}", "$type": "color" },
    "sage-dim": { "$value": "{primitive.color.sage.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ink-deep": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 7vw, 5.8rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.04", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(92, 122, 99, 0.28), rgba(34, 48, 38, 0.12) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(33, 29, 23, 0.95) 0%, rgba(33, 29, 23, 0.32) 42%, rgba(33, 29, 23, 0.58) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.sage.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.sage.700}", "$type": "color" },
      "ghost-border": { "$value": "rgba(247, 242, 231, 0.4)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.sage.500}", "$type": "color" }
    }
  }
}
